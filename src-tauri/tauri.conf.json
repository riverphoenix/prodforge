{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ProdForge",
  "version": "1.0.0",
  "identifier": "com.dsotiriou.prodforge",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ProdForge",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 768,
        "titleBarStyle": "Overlay"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "externalBin": [
      "binaries/prodforge-sidecar"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "Entitlements.plist",
      "minimumSystemVersion": "10.15",
      "dmg": {
        "appPosition": { "x": 180, "y": 170 },
        "applicationFolderPosition": { "x": 480, "y": 170 },
        "windowSize": { "width": 660, "height": 400 }
      }
    },
    "category": "DeveloperTool",
    "shortDescription": "AI-powered Product Management toolkit",
    "longDescription": "ProdForge is an AI-powered desktop toolkit for Product Managers. Generate frameworks, manage documents, run workflows, and chat with AI models from OpenAI, Anthropic, Google, and Ollama."
  }
}
